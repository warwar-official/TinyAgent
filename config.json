{
    "providers": [
        {
            "name": "gemini",
            "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/",
            "structure": "google-compatible"
        },
        {
            "name": "lmstudio",
            "endpoint": "http://192.168.50.212:1234/v1/",
            "structure": "openai-compatible"
        }
    ],
    "agent": {
        "model": {
            "model_id": "gemma-3-27b-it",
            "provider": "gemini",
            "api_key_name": "GEMINI_API_KEY",
            "vision_enabled": true
        },
        "summary_model": {
            "model_id": "gemma-3-12b-it",
            "provider": "gemini",
            "api_key_name": "GEMINI_API_KEY",
            "vision_enabled": false
        }
    },
    "context": {
        "prompts_path": "./data/prompts.json",
        "conversation_history_path": "./data/history/conversation_history.json",
        "task_history_path": "./data/history/task_history.json",
        "tasks_path": "./data/history/tasks.json",
        "state_path": "./data/state.json",
        "memory": {
            "active": true,
            "db_path": "./data/memory/db/",
            "models_cache_path": "./data/memory/models/",
            "emb_model_name": "intfloat/multilingual-e5-large",
            "merge_model": {
                "model_id": "gemma-3-4b-it",
                "provider": "gemini",
                "api_key_name": "GEMINI_API_KEY",
                "vision_enabled": false
            }
        },
        "mcp_config_path": "./tools/mcp_config.json"
    },
    "plugins": {
        "telegram": {
            "secret_path": "./data/telegram_secret.json"
        }
    }
}